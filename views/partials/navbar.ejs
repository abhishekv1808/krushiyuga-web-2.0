<script>
  /* ── Mobile nav toggle ── */
  function toggleMobileNav() {
    const menu = document.getElementById('mobileMenu');
    const btn  = document.getElementById('hamburgerBtn');
    menu.classList.toggle('open');
    btn.classList.toggle('open');
  }

  /* ── Mobile accordion ── */
  function toggleMobileAccordion(bodyId, chevronId) {
    const body    = document.getElementById(bodyId);
    const chevron = document.getElementById(chevronId);
    body.classList.toggle('open');
    chevron.style.transform = body.classList.contains('open') ? 'rotate(180deg)' : 'rotate(0deg)';
  }

  /* ── Desktop dropdown click toggle (fallback for touch) ── */
  function toggleDesktopDropdown(event, dropdownId) {
    event.stopPropagation();
    const el = document.getElementById(dropdownId);
    const isOpen = el.classList.contains('open');
    // close all
    document.querySelectorAll('.nav-dropdown.open').forEach(d => {
      d.classList.remove('open');
      const ch = d.querySelector('.drop-chevron');
      if (ch) ch.style.transform = 'rotate(0deg)';
    });
    if (!isOpen) {
      el.classList.add('open');
      const ch = el.querySelector('.drop-chevron');
      if (ch) ch.style.transform = 'rotate(180deg)';
    }
  }

  /* ── Rotate chevron on desktop hover ── */
  document.querySelectorAll('.nav-dropdown').forEach(function(dd) {
    dd.addEventListener('mouseenter', function() {
      const ch = this.querySelector('.drop-chevron');
      if (ch) ch.style.transform = 'rotate(180deg)';
    });
    dd.addEventListener('mouseleave', function() {
      if (!this.classList.contains('open')) {
        const ch = this.querySelector('.drop-chevron');
        if (ch) ch.style.transform = 'rotate(0deg)';
      }
    });
  });

  /* ── Close dropdowns clicking outside ── */
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.nav-dropdown')) {
      document.querySelectorAll('.nav-dropdown.open').forEach(d => {
        d.classList.remove('open');
        const ch = d.querySelector('.drop-chevron');
        if (ch) ch.style.transform = 'rotate(0deg)';
      });
    }
    if (!e.target.closest('#mainNav')) {
      const menu = document.getElementById('mobileMenu');
      const btn  = document.getElementById('hamburgerBtn');
      if (menu.classList.contains('open')) {
        menu.classList.remove('open');
        btn.classList.remove('open');
      }
    }
  });

  /* ── Navbar shrink on scroll ── */
  window.addEventListener('scroll', function() {
    const nav = document.getElementById('mainNav');
    nav.classList.toggle('scrolled', window.scrollY > 20);
  });

  /* ── Active link highlight ── */
  (function() {
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(function(link) {
      const href = link.getAttribute('href');
      if (href && (href === path || (href !== '/' && path.startsWith(href)))) {
        link.classList.add('active');
      }
    });
  })();
</script>
